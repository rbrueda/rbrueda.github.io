---
import { Image } from "astro:assets";
import "../assets/css/tailwind.css";
import "../assets/css/main.css";
import devpostIcon from "../assets/images/devpost.svg";
---
<!-- todo: fix mobile bug file explorer header -->
<!-- todo: fix mobile bug arrow down button cut off (remove the -, +, x in mobile)-->
<!-- todo: fix mobile bug e cut off in experience in mobile (change size for headers in smaller mobile screens -- or just change headers for mobile screens in general) -->
 <!-- todo: make left, right, and bottom banner thinner for mobile screen -->
  <!-- todo: change border if screen is still small horizontal (width wide but height small) -> change the border so it is is as thin as vertical mobile -->
<!DOCTYPE HTML>
<html lang="en">
	<head>
        <title>Rocio Rueda</title>
		<!-- todo add icon here -->
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width" />
		<!-- todo: look into SOD -->
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Clicker+Script&family=Quicksand&family=Lora&family=Nunito&family=Emilys+Candy&family=Princess+Sofia&family=Spirax&display=swap" rel="stylesheet">
        <script src="https://kit.fontawesome.com/4c4d3c7d2b.js"></script>
    </head>

	<!-- Main body tag for background styling -->
	<body class="min-h-screen bg-gradient-to-br from-[#241B35] via-[#4F3B66] to-[#7E5D8E] bg-fixed">
		<!-- adds curved corners in frame -->
		<div class="fixed inset-0 pointer-events-none z-[45] pt-16 pb-8 px-8 md:p-16">
			<div class="w-full h-full rounded-xl md:rounded-[1rem] shadow-[0_0_0_50px_#2A1B2E]"></div>
		</div>
		
		<!-- nav bar top -->
		<nav class="fixed top-0 left-0 w-full h-12 md:h-16 bg-[#2A1B2E] z-50 flex justify-between items-center px-4 md:px-8 ">
			<!-- Camera icon -->
			<div class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 flex items-center justify-center w-3 h-3 md:w-4 md:h-4 rounded-full bg-[#110B13] shadow-[inset_0_1px_3px_rgba(0,0,0,0.8)]" aria-hidden="true">
				<div class="w-1.5 h-1.5 md:w-2 md:h-2 rounded-full bg-[#4A5568] flex items-start justify-end p-[1px] md:p-[2px]"></div>
				
				<!-- Sparkle/Flash element -->
				<div class="absolute -right-3 -top-2 md:-right-4 md:-top-2 w-1.5 h-1.5 bg-white rounded-full opacity-0 pointer-events-none camera-flash"></div>
			</div>
			
			<!-- Hero Section Link -->
			<a href="#home" class="hover:bg-[#503C67] transition-colors relative z-10">
				<!-- todo: add icon here I made -->
				<div class="flex items-center text-white text-xl md:text-2xl">
					<i class="fas fa-laptop mr-2" aria-hidden="true"></i> Rocio
				</div>
			</a>
			
			<!-- Hamburger menu for smaller width -->
			<div id="mobile-menu" class="fixed top-16 right-0 w-80 bg-[#2A1B2E] border-b border-l border-white/10 shadow-2xl z-40 hidden flex-col pb-16 pl-20 rounded-bl-full lg:hidden">
				<ul class="flex flex-col gap-6 text-white/90 font-bold text-2xl text-center list-none w-full pr-4 mt-6">
					<li><a href="#about" class="mobile-link block w-full py-2 hover:text-[#d68fb4] transition-colors">About</a></li>
					<li><a href="#experience" class="mobile-link block w-full py-2 hover:text-[#d68fb4] transition-colors">Experience</a></li>
					<li><a href="#projects" class="mobile-link block w-full py-2 hover:text-[#d68fb4] transition-colors">Projects</a></li>
					<li><a href="#contact" class="mobile-link block w-full py-2 hover:text-[#d68fb4] transition-colors">Contact</a></li>
				</ul>
			</div>
			
			<!-- Original menu elsewise -->
			<ul class="hidden lg:flex gap-6 text-white/90 font-bold list-none text-xl md:text-2xl relative z-10">
				<li><a href="#about" class="hover:bg-[#503C67] rounded-lg transition-colors">About</a></li>
				<li><a href="#experience" class="hover:bg-[#503C67] rounded-lg transition-colors">Experience</a></li>
				<li><a href="#projects" class="hover:bg-[#503C67] rounded-lg transition-colors">Projects</a></li>
				<li><a href="#contact" class="hover:bg-[#503C67] rounded-lg transition-colors">Contact</a></li>
			</ul>

			<!-- Button for Hamburger menu -->
			<button id="mobile-menu-btn" aria-label="Toggle mobile menu" class="lg:hidden text-white text-2xl focus:outline-none w-8 h-8 flex items-center justify-center relative z-10">
				<i class="fas fa-bars transition-transform duration-300" aria-hidden="true"></i>
			</button>
		</nav>

		<!-- nav bar bottom -->
		<nav class="fixed bottom-0 left-0 w-full h-6 md:h-16 bg-[#2A1B2E] z-50 flex justify-center items-center">
		</nav>
		
		<!-- nav bar left -->
		<nav class="fixed top-16 md:top-16 left-0 w-6 md:w-16 h-[calc(100vh-3rem)] md:h-[calc(100vh-8rem)] bg-[#2A1B2E] z-50 flex flex-col justify-center items-center gap-8 ">
		</nav>

		<!-- nav bar right -->
		<nav class="fixed top-16 md:top-16 right-0 w-6 md:w-16 h-[calc(100vh-3rem)] md:h-[calc(100vh-8rem)] bg-[#2A1B2E] z-50 flex flex-col justify-center items-center ">
		</nav>
		
		<!-- main tag that ensures consistent padding across the web page -->
		<main class="pt-24 pb-20 px-12 md:px-24 w-full min-h-screen">
			<!-- Home/Hero Section -->
			<section id="home" class="min-h-[85vh] flex flex-col items-center pt-28 px-4 fade-content visible">
				<!-- Avatar container -->
				<div class="relative w-56 h-56 md:w-64 md:h-64 lg:w-80 lg:h-80 rounded-full border border-white/50 overflow-hidden mb-6 
					shadow-[inset_0_0_0_1px_rgba(222,181,202,0.35),0_0_8px_0_rgba(222,181,202,0.8)]
					transition-all duration-500 ease-in-out
					hover:-translate-y-3 animate-fade-up">
					<Image
						src={import("../assets/images/avatar.jpg")}
						alt="Rocio Rueda"
						width={640}  
						height={640} 
						format="webp"
						class="object-cover w-full h-full"
					/>
				</div>
				<!-- Info and pitch text -->
				<div class="flex flex-col gap-2 transition-all duration-500 ease-in-out hover:-translate-y-2 animate-fade-up delay-100">
					<h1 class="text-4xl font-bold text-center text-white">Rocio Rueda</h1>
					<h3 class="text-xl md:text-2xl font-bold text-center text-white bg-black/20 p-2 rounded-xl">Software and ML Enthusiast</h3>
					<h3 class="relative flex items-center justify-center text-lg md:text-xl font-bold text-white bg-black/30 overflow-hidden rounded-xl">
						<span class="py-2 px-12">BSc Computer Science Student</span>
						<div class="absolute right-0 top-0 bottom-0 w-12 flex items-center justify-center text-white/50 hover:text-white hover:bg-[#DEB5CA] cursor-pointer transition-colors">
							<i class="fas fa-long-arrow-alt-right" aria-hidden="true"></i>
						</div>
					</h3>
				</div>
				<!-- Social media buttons -->
				<ul class="flex justify-center pt-6 gap-4 animate-fade-up delay-200">
					<!-- LinkedIn -->
					<li>
						<a
						href="https://www.linkedin.com/in/rocio-rueda-705a4a26a/" aria-label="LinkedIn Profile"
						class="relative block rounded-full border border-white/25 bg-white/10 p-6
								transition-all duration-200 ease-in-out hover:bg-white/25
								max-[736px]:p-5">
						<i class="fab fa-linkedin absolute top-1/2 left-1/2 text-[20px] text-white -translate-x-1/2 -translate-y-1/2 max-[736px]:text-[16px]" aria-hidden="true"></i>
						</a>
					</li>
					<!-- GitHub -->
					<li>
						<a
						href="https://github.com/rbrueda" aria-label="GitHub Profile"
						class="relative block rounded-full border border-white/25 bg-white/10 p-6
								transition-all duration-200 ease-in-out hover:bg-white/25
								max-[736px]:p-5">
						<i class="fab fa-github absolute top-1/2 left-1/2 text-[20px] text-white -translate-x-1/2 -translate-y-1/2 max-[736px]:text-[16px]" aria-hidden="true"></i>
						</a>
					</li>

					<!-- Devpost -->
					<!-- since devpost does not have built-in Font Awesome class, this approach allows it to behave like one -->
					<li>
						<a
						href="https://devpost.com/rbrueda"
						class="relative block rounded-full border border-white/25 bg-white/10 p-6
								transition-all duration-200 ease-in-out hover:bg-white/25
								max-[736px]:p-5">
						<span
							aria-hidden="true"
							style={`-webkit-mask-image: url('${devpostIcon.src}'); mask-image: url('${devpostIcon.src}');`}
							class="absolute top-1/2 left-1/2 h-[20px] w-[20px] bg-white
								-translate-x-1/2 -translate-y-1/2
								[-webkit-mask-repeat:no-repeat]
								[mask-repeat:no-repeat]
								[-webkit-mask-position:center]
								[mask-position:center]
								[-webkit-mask-size:contain]
								[mask-size:contain]
								max-[736px]:h-[16px] max-[736px]:w-[16px]"
						></span>
						<span class="sr-only">Devpost</span>
						</a>
					</li>
					<!-- Email -->
					<li>
						<a
						href="mailto:rbrueda8@gmail.com" aria-label="Send an Email"
						class="relative block rounded-full border border-white/25 bg-white/10 p-6
								transition-all duration-200 ease-in-out hover:bg-white/25
								max-[736px]:p-5">
						<i class="fas fa-envelope absolute top-1/2 left-1/2 text-[20px] text-white -translate-x-1/2 -translate-y-1/2 max-[736px]:text-[16px]" aria-hidden="true"></i>
						</a>
					</li>
				</ul>
			
				<!-- Button for see more info below in Hero -->
				<div class="mt-auto pt-12 pb-4 animate-fade-up delay-300">
					<a href="#about" class="flex items-center justify-center w-8 h-8 rounded-full bg-[#DEB5CA]/40 text-white/70 hover:text-white hover:bg-[#DEB5CA] transition-all duration-700 animate-bounce"
						aria-label="Scroll to About section">
						<i class="fas fa-chevron-down text-lg" aria-hidden="true"></i>
					</a>
            	</div>
			</section>

			<!-- About Section -->
			<section id="about">
				<!-- floral divider per section -->
				<div class="reveal flex items-center justify-center w-full max-w-2xl mx-auto my-12 opacity-90">
					<div class="h-px flex-1 bg-gradient-to-r from-transparent to-white/60"></div>
					<div class="px-4 text-white drop-shadow-[0_0_8px_rgba(255,255,255,0.7)]">
						<svg aria-hidden="true" class="w-56 h-16 md:w-64 md:h-20" viewBox="0 0 250 60" fill="none" xmlns="http://www.w3.org/2000/svg">	
							<path d="M 10 30 C 80 30, 100 10, 125 30 C 150 50, 170 30, 240 30" stroke="currentColor" stroke-width="2" stroke-linecap="round" fill="none"/>
							<path d="M 105 15 C 105 5, 95 5, 95 15 C 85 15, 85 25, 95 25 C 95 35, 105 35, 105 25 C 115 25, 115 15, 105 15 Z" fill="currentColor"/>
							<circle cx="100" cy="20" r="2.5" fill="#4F3B66"/>
							<path d="M 145 40 C 145 30, 155 30, 155 40 C 165 40, 165 50, 155 50 C 155 60, 145 60, 145 50 C 135 50, 135 40, 145 40 Z" fill="currentColor"/>
							<circle cx="150" cy="45" r="2.5" fill="#4F3B66"/>
							<path d="M 50 30 Q 60 20 70 30 Q 60 35 50 30 Z" fill="currentColor"/>
							<path d="M 200 30 Q 190 40 180 30 Q 190 25 200 30 Z" fill="currentColor"/>	
						</svg>
					</div>
					<div class="h-px flex-1 bg-gradient-to-l from-transparent to-white/60"></div>
				</div>

				<!-- About Header -->
				<h1 class="reveal text-4xl md:text-6xl font-bold text-center text-white pb-8">About</h1>

				<!-- About me content -->
				<!-- div for dividing photo and text content -->
				<div class="reveal flex flex-col lg:flex-row gap-8 lg:gap-12 items-center lg:items-start w-full max-w-[1200px] mx-auto px-4 lg:px-0">
    				<!-- Photo content -->
					<div class="w-full lg:w-1/2 flex flex-col rounded-xl bg-black/10 border border-white/10 shadow-2xl overflow-hidden">
						<!-- Photo Header content -->
						<div class="h-10 flex items-center justify-between px-2 bg-black/20 border-b border-white/5 text-white/80 text-xs select-none">
							<div class="flex items-center gap-3 pl-2">
								<i class="fas fa-arrow-left text-white/50 hover:text-white cursor-pointer transition-colors" aria-hidden="true"></i>
								<div class="border-l border-white/20 h-4 mx-1"></div>
								<span class="hover:bg-white/10 px-2 py-1 rounded cursor-pointer hidden sm:block transition-colors">File</span>
								<span class="hover:bg-white/10 px-2 py-1 rounded cursor-pointer hidden sm:block transition-colors">Edit</span>
								<span class="hover:bg-white/10 px-2 py-1 rounded cursor-pointer hidden sm:block transition-colors">View</span>
							</div>
							<div class="flex-1 text-center font-semibold tracking-wide text-white/90 truncate px-4">
								AboutMe.jpg
							</div>
							<div class="flex items-center" aria-hidden="true">
								<button class="w-8 h-8 flex items-center justify-center hover:bg-white/10 rounded transition-colors"><i class="fas fa-minus text-[10px]"></i></button>
								<button class="w-8 h-8 flex items-center justify-center hover:bg-white/10 rounded transition-colors"><i class="far fa-square text-[11px]"></i></button>
								<button class="w-8 h-8 flex items-center justify-center hover:bg-[#DEB5CA] rounded transition-colors"><i class="fas fa-times text-[14px]"></i></button>
							</div>
        				</div>
						<!-- Image content -->
						<div class="relative h-72 md:h-96 overflow-hidden">
							<Image 
								src={import("../assets/images/about/about.jpg")} 
								alt="About" 
								width={3024} 
								height={3365} 
								format="webp" 
								loading="lazy" 
								class="absolute block w-full h-full object-contain -translate-x-1/2 -translate-y-1/2 top-1/2 left-1/2 transition-transform duration-500 hover:scale-125 cursor-zoom-in" 
							/>
						</div>
						<!-- Photo Footer content -->
						<div class="h-10 flex items-center justify-between px-4 border-t border-white/5 text-white/50 text-[11px] select-none">
							<div>3,024 × 3,365 &nbsp;|&nbsp; 1.9 MB</div>
							<div class="flex items-center gap-3">
								<span class="hidden sm:inline-block">50%</span>
								<!-- Fake zoom in feature -->
								<i class="fas fa-search-minus cursor-pointer hover:text-white transition-colors" aria-hidden="true"></i>
								<div class="w-20 md:w-32 h-1 bg-white/20 rounded-full relative cursor-pointer">
									<div class="absolute left-1/2 top-1/2 -translate-y-1/2 -translate-x-1/2 w-3 h-3 bg-[#DEB5CA] rounded-full hover:scale-110 transition-transform"></div>
								</div>
								<i class="fas fa-search-plus cursor-pointer hover:text-white transition-colors" aria-hidden="true"></i>
							</div>
						</div>
    				</div>
					
					<!-- Text Content -->
					<div class="w-full lg:w-1/2 flex flex-col justify-center text-white/90">
						<!-- Quote content -->
						<blockquote class="border-l-4 border-[#deb5ca] pl-4 md:pl-6 italic text-white/80 mb-8 py-2 pr-1 bg-white/5 rounded-r-lg">
							“Give your dreams all you’ve got, and you’ll be amazed at the energy that comes out of you.”<br/>
							<span class="text-sm font-semibold text-[#deb5ca] mt-2 inline-block">— William James</span>
						</blockquote>
						<!-- Paragraph content -->
						<div class="space-y-5 text-base md:text-lg leading-relaxed font-semibold">
							<p>Hi, I’m <strong class="text-[#deb5ca] text-xl">Rocio</strong>. I’m a Computer Science student at the University of Windsor specializing in Artificial Intelligence.</p>
							<p>While my interest in computer science grew during university, my curiosity for building things started long before that. I’ve always enjoyed experimenting, creating, and figuring out how things work, whether through art or code.</p>
							<p>Somewhere along the way, programming became the place where all of that finally clicked. My current interests sit between software development and machine learning, and I’m always excited to learn new tools and technologies along the way!</p>
						</div>
					</div>
				</div>
			</section>


			<!-- Experience Section -->
			<section id="experience" class="page-section w-full px-4 pt-12">
				<!-- floral divider per section -->
				<div class="reveal flex items-center justify-center w-full max-w-2xl mx-auto my-12 opacity-90">
					<div class="h-px flex-1 bg-gradient-to-r from-transparent to-white/60"></div>
					<div class="px-4 text-white drop-shadow-[0_0_8px_rgba(255,255,255,0.7)]">
						<svg aria-hidden="true" class="w-56 h-16 md:w-64 md:h-20" viewBox="0 0 250 60" fill="none" xmlns="http://www.w3.org/2000/svg">		
							<path d="M 10 30 C 80 30, 100 10, 125 30 C 150 50, 170 30, 240 30" stroke="currentColor" stroke-width="2" stroke-linecap="round" fill="none"/>
							<path d="M 105 15 C 105 5, 95 5, 95 15 C 85 15, 85 25, 95 25 C 95 35, 105 35, 105 25 C 115 25, 115 15, 105 15 Z" fill="currentColor"/>
							<circle cx="100" cy="20" r="2.5" fill="#4F3B66"/>
							<path d="M 145 40 C 145 30, 155 30, 155 40 C 165 40, 165 50, 155 50 C 155 60, 145 60, 145 50 C 135 50, 135 40, 145 40 Z" fill="currentColor"/>
							<circle cx="150" cy="45" r="2.5" fill="#4F3B66"/>
							<path d="M 50 30 Q 60 20 70 30 Q 60 35 50 30 Z" fill="currentColor"/>
							<path d="M 200 30 Q 190 40 180 30 Q 190 25 200 30 Z" fill="currentColor"/>		
						</svg>
					</div>	
					<div class="h-px flex-1 bg-gradient-to-l from-transparent to-white/60"></div>
				</div>
				
				<!-- Experience Header -->
				<h1 class="reveal text-4xl md:text-6xl font-bold text-center text-white pb-8">Experience</h1>
				
				<!-- File Explorer container  -->
				<div class="reveal mx-auto w-full max-w-[1400px] rounded-xl backdrop-blur-md border border-white/20 shadow-2xl overflow-hidden flex flex-col font-['Quicksand',_sans-serif]">
									
					<!-- File header -->
					<div class="h-10 flex items-center justify-between border-b border-white/10 pl-4">
						<div class="flex items-center gap-2 text-white/90 text-sm font-semibold tracking-wide">
							<i class="fas fa-folder-open text-[#DEB5CA]/70" aria-hidden="true"></i>
							<span>C:\Users\Rocio\Experience</span>
						</div>
						<div class="flex h-full" aria-hidden="true">
							<button class="w-12 h-full flex items-center justify-center text-white/80 hover:bg-white/20 hover:text-white transition-colors">
								<i class="fas fa-minus text-[10px]"></i>
							</button>
							<button class="w-12 h-full flex items-center justify-center text-white/80 hover:bg-white/20 hover:text-white transition-colors">
								<i class="far fa-square text-[11px]"></i>
							</button>
							<button class="w-12 h-full flex items-center justify-center text-white/80 hover:bg-[#DEB5CA] hover:text-white transition-colors">
								<i class="fas fa-times text-[14px]"></i>
							</button>
						</div>
					</div>

					<!-- File path and search content section (Hidden until lg breakpoint) -->
					<div class="h-14 border-b border-white/10 text-white flex items-center px-4 gap-4 lg:gap-6 text-sm hidden lg:flex">
						
						<div class="flex items-center gap-4 text-white/40 shrink-0" aria-hidden="true">
							<i class="fas fa-arrow-left hover:text-white cursor-pointer transition-colors"></i>
							<i class="fas fa-arrow-right hover:text-white cursor-pointer transition-colors"></i>
							<i class="fas fa-arrow-up hover:text-white cursor-pointer transition-colors"></i>
							<i class="fas fa-redo hover:text-white cursor-pointer transition-colors"></i>
						</div>
						
						<!-- Address Bar with Flexbox truncation -->
						<div class="flex-1 min-w-0 bg-white/5 rounded px-3 py-2 flex items-center gap-2 border border-white/10 shadow-inner" role="navigation" aria-hidden="true">
							<i class="fas fa-desktop text-white/40 shrink-0"></i>
							<span class="text-white/80 truncate">
								<span>This PC > Documents > Experience</span>
							</span>
						</div>
						
						<!-- Search Bar -->
						<div class="w-48 xl:w-64 shrink-0 bg-white/5 rounded px-3 py-2 flex items-center justify-between border border-white/10 shadow-inner">
							<span class="text-white/40 italic truncate">Search Experience...</span>
							<i class="fas fa-search text-white/40 shrink-0" aria-hidden="true"></i>
						</div>
					</div>

					<!-- Main Content Split (skills and experience) -->
					<div class="flex flex-col lg:flex-row h-auto lg:h-[600px] p-4 lg:p-6 gap-4 lg:gap-6">
						
						<!-- Quick Access Sidebar -->
						<div class="w-full lg:w-1/4 xl:w-1/5 bg-black/10 border border-white/10 rounded-lg p-4 overflow-y-auto shadow-inner custom-scrollbar">
							<h3 class="text-xs lg:text-sm font-bold text-white uppercase tracking-wider mb-4 pl-2">Quick Access</h3>
							
							<ul class="grid grid-cols-2 lg:flex lg:flex-col gap-2 lg:gap-1 text-sm lg:text-base text-white font-semibold">
								<li class="flex items-center gap-2 lg:gap-3 px-2 lg:px-3 py-2 lg:py-3 hover:bg-white/10 rounded cursor-pointer transition-colors">
									<i class="fab fa-python text-[#deb5ca] text-lg w-5 text-center" aria-hidden="true"></i> <span>Python</span>
								</li>
								<li class="flex items-center gap-2 lg:gap-3 px-2 lg:px-3 py-2 lg:py-3 hover:bg-white/10 rounded cursor-pointer transition-colors">
									<i class="fas fa-fire text-[#deb5ca] text-lg w-5 text-center" aria-hidden="true"></i> <span>PyTorch</span>
								</li>
								<li class="flex items-center gap-2 lg:gap-3 px-2 lg:px-3 py-2 lg:py-3 hover:bg-white/10 rounded cursor-pointer transition-colors">
									<i class="fas fa-table text-[#deb5ca] text-lg w-5 text-center" aria-hidden="true"></i> <span>Pandas</span>
								</li>
								<li class="flex items-center gap-2 lg:gap-3 px-2 lg:px-3 py-2 lg:py-3 hover:bg-white/10 rounded cursor-pointer transition-colors">
									<i class="fab fa-java text-[#deb5ca] text-lg w-5 text-center" aria-hidden="true"></i> <span>Java</span>
								</li>
								<li class="flex items-center gap-2 lg:gap-3 px-2 lg:px-3 py-2 lg:py-3 hover:bg-white/10 rounded cursor-pointer transition-colors">
									<i class="fab fa-js text-[#deb5ca] text-lg w-5 text-center" aria-hidden="true"></i> <span>JavaScript</span>
								</li>
